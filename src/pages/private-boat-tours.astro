---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Private Boat Tours - Boat Rodos">
  <section class="hero-2 bg-cover" style="background-image: url('/assets/img/charter-bases-visual.png')">
    <div class="container custom-container-3">
      <div class="row">
        <div class="col-lg-8">
          <div class="hero-content">
            <div class="sub-title">Services</div>
            <h1>Private Boat Tours</h1>
            <p>A fully private boat experience tailored to your wishes.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-sky-50">
    <div class="container">
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
        <div class="w-full lg:w-1/2 wow fadeInUp">
          <div class="overflow-hidden rounded-2xl" style="box-shadow: rgb(56, 84, 107) -7px 7px 0px;">
            <img src="/assets/img/charter-bases-visual.png" alt="Private Boat Tours" class="w-full h-[22rem] sm:h-[26rem] object-cover" />
          </div>
        </div>
        <div class="w-full lg:w-1/2 wow fadeInUp" data-wow-delay=".2s">
          <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: var(--header);">Your Own Private Experience</h2>
          <p class="text-lg leading-relaxed mb-6" style="color: var(--text);">
            Whether it is a romantic sunset cruise, a family day out or a celebration with friends, our private tours offer complete flexibility with a dedicated skipper and crew. You decide the route, the pace and the stops.
          </p>
          <p class="text-lg leading-relaxed mb-6" style="color: var(--text);">
            Every detail is customized to your preferences including catering, music, water sports equipment and special occasion arrangements. Perfect for birthdays, anniversaries, proposals and corporate events.
          </p>
          <a href="/contact" class="theme-btn">
            <span>Book a Private Tour <i class="bi bi-arrow-right"></i></span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
