---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Rodos Boat Tours - Boat Rodos">
  <section class="hero-2 bg-cover" style="background-image: url('/assets/img/charter-bases-visual.png')">
    <div class="container custom-container-3">
      <div class="row">
        <div class="col-lg-8">
          <div class="hero-content">
            <div class="sub-title">Services</div>
            <h1>Rodos Boat Tours</h1>
            <p>Guided boat tours to discover hidden coves, secluded beaches and picturesque bays around Rhodes.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-sky-50">
    <div class="container">
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
        <div class="w-full lg:w-1/2 wow fadeInUp">
          <div class="overflow-hidden rounded-2xl" style="box-shadow: rgb(56, 84, 107) -7px 7px 0px;">
            <img src="/assets/img/charter-bases-visual.png" alt="Rodos Boat Tours" class="w-full h-[22rem] sm:h-[26rem] object-cover" />
          </div>
        </div>
        <div class="w-full lg:w-1/2 wow fadeInUp" data-wow-delay=".2s">
          <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: var(--header);">Explore Rhodes by Boat</h2>
          <p class="text-lg leading-relaxed mb-6" style="color: var(--text);">
            Join one of our guided boat tours and discover hidden coves, secluded beaches and picturesque bays around Rhodes. Our experienced captains will take you to the best spots while sharing stories and local knowledge about the island.
          </p>
          <p class="text-lg leading-relaxed mb-6" style="color: var(--text);">
            Each tour includes swimming stops in crystal-clear waters, snorkeling equipment and refreshments on board. Choose from half-day morning tours, afternoon sunset cruises or full-day island explorations.
          </p>
          <a href="/contact" class="theme-btn">
            <span>Book a Tour <i class="bi bi-arrow-right"></i></span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
