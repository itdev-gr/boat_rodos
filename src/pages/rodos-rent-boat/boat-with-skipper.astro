---
import Layout from '../../layouts/Layout.astro';

const skipperBenefits = [
  { icon: 'bi-map', title: 'Local Knowledge', text: 'Our skippers know every hidden cove, secluded beach and scenic route along the Rhodes coastline.' },
  { icon: 'bi-shield-check', title: 'Safety & Confidence', text: 'A certified skipper on board means you can relax knowing the boat is in expert hands at all times.' },
  { icon: 'bi-person-badge', title: 'Personal Guide', text: 'More than a captain — your skipper shares stories, history and insider tips about every stop.' },
  { icon: 'bi-clock', title: 'More Time to Enjoy', text: 'No navigating, no docking stress. Spend your time swimming, snorkeling and taking in the views.' },
  { icon: 'bi-signpost-split', title: 'Best Routes', text: 'Your skipper plans the optimal route based on weather, sea conditions and your preferences.' },
  { icon: 'bi-camera', title: 'Photo Opportunities', text: 'Our skippers know the best angles and viewpoints for stunning photos of the coastline and your group.' },
];

const destinations = [
  { name: 'Lindos Bay', desc: 'Iconic village with a stunning acropolis overlooking a turquoise bay.' },
  { name: 'Stegna Beach', desc: 'A sheltered pebble beach with crystal-clear water and beachfront tavernas.' },
  { name: 'Kalathos', desc: 'A quiet stretch of coastline perfect for swimming and snorkeling in peace.' },
  { name: 'St. Paul\'s Bay & Vlicha', desc: 'A picture-perfect cove framed by dramatic cliffs and warm shallow waters.' },
  { name: 'Agathi Beach', desc: 'A golden sandy beach near Haraki, ideal for a relaxed afternoon stop.' },
  { name: 'Red Sand Beach', desc: 'A unique red-hued shoreline surrounded by striking volcanic rock formations.' },
];
---

<Layout title="Boat Rental with Skipper - Rodos Rent Boat">
  <!-- Hero -->
  <section class="hero-2 bg-cover" style="background-image: url('/assets/img/rent-boat-aerial.jpg')">
    <div class="container custom-container-3">
      <div class="row">
        <div class="col-lg-8">
          <div class="hero-content">
            <div class="sub-title">Rodos Rent Boat</div>
            <h1>Boat Rental with Skipper</h1>
            <p>Sit back, relax and let our experienced skipper navigate you to the most beautiful spots around Rhodes.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Skipper Intro -->
  <section class="py-24 bg-sky-50">
    <div class="container">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
        <div class="w-full lg:w-1/2 wow fadeInUp">
          <div class="relative">
            <div class="overflow-hidden rounded-2xl" style="box-shadow: rgb(56, 84, 107) -7px 7px 0px;">
              <img src="/assets/img/rent-boat-1.jpg" alt="Boat with Skipper Rhodes" class="w-full h-[26rem] sm:h-[32rem] object-cover" />
            </div>
            <!-- Floating accent card -->
            <div class="hidden sm:flex absolute -bottom-8 -right-8 bg-white rounded-2xl p-6 items-center gap-4" style="box-shadow: 0 15px 40px rgba(0,0,0,0.1);">
              <div class="w-14 h-14 rounded-full flex items-center justify-center text-white text-xl" style="background: linear-gradient(135deg, #113D48, #1CA8CB);">
                <i class="bi bi-plus-lg"></i>
              </div>
              <div>
                <p class="text-2xl font-bold" style="color: var(--header);">+€10</p>
                <p class="text-sm" style="color: var(--text);">per hour</p>
              </div>
            </div>
          </div>
        </div>
        <div class="w-full lg:w-1/2 wow fadeInUp" data-wow-delay=".2s">
          <span class="text-sm uppercase tracking-widest font-semibold mb-3 inline-block" style="color: var(--theme); font-family: 'Kalam', sans-serif;">The Skipper Experience</span>
          <h2 class="text-3xl sm:text-4xl font-bold mb-6" style="color: var(--header);">Let Us Take<br />the Helm</h2>
          <p class="text-lg leading-relaxed mb-5" style="color: var(--text);">
            Adding a professional skipper to your boat rental transforms your trip into a fully guided experience. Our skippers are licensed, experienced and born-and-raised locals who know the Rhodes coastline like the back of their hand.
          </p>
          <p class="text-lg leading-relaxed mb-5" style="color: var(--text);">
            Your skipper handles all the navigation, docking and safety — so you can focus entirely on enjoying the crystal-clear waters, discovering hidden beaches and soaking up the sun.
          </p>
          <p class="text-lg leading-relaxed" style="color: var(--text);">
            The skipper add-on is available for just <strong>€10 per hour</strong> on top of the standard boat rental rate. It is the perfect choice for those who want a stress-free, premium experience on the water.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Bar -->
  <section class="py-20 relative overflow-hidden" style="background: linear-gradient(135deg, #0A1F24 0%, #113D48 50%, #1CA8CB 100%);">
    <div class="container relative z-10">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
        {[
          { icon: 'bi-speedometer', number: '€75+', label: 'Medium + Skipper / hr' },
          { icon: 'bi-speedometer2', number: '€100+', label: 'Large + Skipper / hr' },
          { icon: 'bi-plus-circle', number: '+€10', label: 'Skipper Add-on / hr' },
          { icon: 'bi-clock', number: '09-18', label: 'Daily Availability' },
        ].map((s) => (
          <div class="text-center wow fadeInUp">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full border border-white/20 flex items-center justify-center text-white text-2xl">
              <i class={`bi ${s.icon}`}></i>
            </div>
            <p class="text-4xl sm:text-5xl font-bold text-white mb-2">{s.number}</p>
            <p class="text-white/60 text-sm uppercase tracking-widest">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
    <div class="absolute -top-24 -left-24 w-72 h-72 rounded-full border border-white/5"></div>
    <div class="absolute -bottom-32 -right-32 w-96 h-96 rounded-full border border-white/5"></div>
  </section>

  <!-- Why a Skipper -->
  <section class="py-24 bg-white">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-16 wow fadeInUp">
        <span class="text-sm uppercase tracking-widest font-semibold mb-3 inline-block" style="color: var(--theme); font-family: 'Kalam', sans-serif;">Why a Skipper</span>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: var(--header);">The Benefits of a<br />Guided Experience</h2>
        <p class="text-lg" style="color: var(--text);">More than just a captain — your skipper is your local guide, navigator and safety expert.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {skipperBenefits.map((b, i) => (
          <div class="bg-sky-50 rounded-2xl p-8 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 wow fadeInUp" data-wow-delay={`${0.1 * i}s`}>
            <div class="w-14 h-14 rounded-xl flex items-center justify-center text-white text-xl mb-6" style="background: linear-gradient(135deg, #113D48, #1CA8CB);">
              <i class={`bi ${b.icon}`}></i>
            </div>
            <h3 class="text-xl font-bold mb-3" style="color: var(--header);">{b.title}</h3>
            <p class="leading-relaxed" style="color: var(--text);">{b.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What Skipper Provides -->
  <section class="py-24 bg-sky-50">
    <div class="container">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
        <div class="w-full lg:w-1/2 wow fadeInUp">
          <span class="text-sm uppercase tracking-widest font-semibold mb-3 inline-block" style="color: var(--theme); font-family: 'Kalam', sans-serif;">Your Skipper Provides</span>
          <h2 class="text-3xl sm:text-4xl font-bold mb-8" style="color: var(--header);">A Complete<br />Service on Board</h2>
          <div class="flex flex-col gap-4">
            {[
              'Expert navigation and route planning',
              'Continuous safety monitoring',
              'Local knowledge of beaches and coves',
              'Restaurant and taverna recommendations',
              'Assistance with swimming and snorkeling spots',
              'Boat handling, docking and anchoring',
              'Flexible itinerary based on your wishes',
            ].map((item) => (
              <div class="flex items-center gap-3">
                <div class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-white text-sm" style="background-color: var(--theme);">
                  <i class="bi bi-check-lg"></i>
                </div>
                <p class="font-medium" style="color: var(--text);">{item}</p>
              </div>
            ))}
          </div>
        </div>
        <div class="w-full lg:w-1/2 wow fadeInUp" data-wow-delay=".2s">
          <div class="overflow-hidden rounded-2xl" style="box-shadow: rgb(56, 84, 107) -7px 7px 0px;">
            <img src="/assets/img/rent-boat-aerial.jpg" alt="Skipper Service" class="w-full h-[26rem] sm:h-[32rem] object-cover" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Destinations -->
  <section class="py-24 bg-white">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-16 wow fadeInUp">
        <span class="text-sm uppercase tracking-widest font-semibold mb-3 inline-block" style="color: var(--theme); font-family: 'Kalam', sans-serif;">Where to Go</span>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: var(--header);">Popular Destinations</h2>
        <p class="text-lg" style="color: var(--text);">Your skipper knows the best routes to these stunning coastal spots.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {destinations.map((d, i) => (
          <div class="bg-sky-50 rounded-2xl p-8 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 wow fadeInUp" data-wow-delay={`${0.1 * i}s`}>
            <div class="w-12 h-12 rounded-xl flex items-center justify-center text-white text-lg mb-5" style="background: linear-gradient(135deg, #113D48, #1CA8CB);">
              <i class="bi bi-geo-alt"></i>
            </div>
            <h3 class="text-lg font-bold mb-2" style="color: var(--header);">{d.name}</h3>
            <p class="leading-relaxed" style="color: var(--text);">{d.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Both Boats Available -->
  <section class="py-24 bg-sky-50">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-16 wow fadeInUp">
        <span class="text-sm uppercase tracking-widest font-semibold mb-3 inline-block" style="color: var(--theme); font-family: 'Kalam', sans-serif;">Available Boats</span>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: var(--header);">Both Boats Available<br />with Skipper</h2>
        <p class="text-lg" style="color: var(--text);">Add a skipper to either of our boats for a fully guided experience.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <!-- Medium + Skipper -->
        <div class="bg-white rounded-2xl overflow-hidden transition-all duration-300 hover:shadow-xl wow fadeInUp" style="box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
          <div class="overflow-hidden">
            <img src="/assets/img/rent-boat-1.jpg" alt="Nireus 4.90 Optima with Skipper" class="w-full h-56 object-cover" />
          </div>
          <div class="p-8">
            <h3 class="text-2xl font-bold mb-2" style="color: var(--header);">Nireus 4.90 Optima + Skipper</h3>
            <p class="text-sm mb-4" style="color: var(--text);">4.90m · Up to 4 passengers · 15 HP · Professional skipper included</p>
            <p class="text-3xl font-bold mb-1" style="color: var(--theme);">€75<span class="text-base font-normal" style="color: var(--text);">/hour</span></p>
            <p class="text-sm mb-6" style="color: var(--text);">Base €65 + €10 skipper add-on</p>
            <a href="/contact" class="theme-btn">
              <span>Book with Skipper <i class="bi bi-arrow-right"></i></span>
            </a>
          </div>
        </div>
        <!-- Large + Skipper -->
        <div class="bg-white rounded-2xl overflow-hidden transition-all duration-300 hover:shadow-xl wow fadeInUp" data-wow-delay=".2s" style="box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
          <div class="overflow-hidden">
            <img src="/assets/img/rent-boat-aerial.jpg" alt="Karel Paxos 170 with Skipper" class="w-full h-56 object-cover" />
          </div>
          <div class="p-8">
            <h3 class="text-2xl font-bold mb-2" style="color: var(--header);">Karel Paxos 170 + Skipper</h3>
            <p class="text-sm mb-4" style="color: var(--text);">5.00m · Up to 7 passengers · 30 HP · Professional skipper included</p>
            <p class="text-3xl font-bold mb-1" style="color: var(--theme);">€100<span class="text-base font-normal" style="color: var(--text);">/hour</span></p>
            <p class="text-sm mb-6" style="color: var(--text);">Base €90 + €10 skipper add-on</p>
            <a href="/contact" class="theme-btn">
              <span>Book with Skipper <i class="bi bi-arrow-right"></i></span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 relative overflow-hidden" style="background: linear-gradient(135deg, #0A1F24 0%, #113D48 100%);">
    <div class="container relative z-10 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4 wow fadeInUp">Ready for a Guided Adventure?</h2>
      <p class="text-lg text-white/70 mb-10 max-w-xl mx-auto wow fadeInUp" data-wow-delay=".1s">Let our experienced skipper show you the best of Rhodes. Book your guided boat trip today.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center wow fadeInUp" data-wow-delay=".2s">
        <a href="/contact" class="theme-btn">
          <span>Book with Skipper <i class="bi bi-arrow-right"></i></span>
        </a>
        <a href="/rodos-rent-boat/licenses-free" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-full border-2 border-white/30 text-white font-semibold transition-all duration-300 hover:bg-white hover:text-[#0A1F24]">
          Self-Drive Option <i class="bi bi-arrow-right"></i>
        </a>
      </div>
    </div>
    <div class="absolute -top-20 -right-20 w-64 h-64 rounded-full border border-white/5"></div>
    <div class="absolute -bottom-16 -left-16 w-48 h-48 rounded-full border border-white/5"></div>
  </section>
</Layout>
