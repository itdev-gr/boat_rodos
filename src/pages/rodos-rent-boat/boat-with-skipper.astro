---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Boat with Skipper - Rodos Rent Boat">
  <section class="hero-2 bg-cover" style="background-image: url('/assets/img/charter-bases-visual.png')">
    <div class="container custom-container-3">
      <div class="row">
        <div class="col-lg-8">
          <div class="hero-content">
            <div class="sub-title">Rodos Rent Boat</div>
            <h1>Boat with Skipper</h1>
            <p>Sit back and relax while our experienced skipper takes you to the best spots.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-sky-50">
    <div class="container">
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
        <div class="w-full lg:w-1/2 wow fadeInUp">
          <div class="overflow-hidden rounded-2xl" style="box-shadow: rgb(56, 84, 107) -7px 7px 0px;">
            <img src="/assets/img/charter-bases-visual.png" alt="Boat with Skipper" class="w-full h-[22rem] sm:h-[26rem] object-cover" />
          </div>
        </div>
        <div class="w-full lg:w-1/2 wow fadeInUp" data-wow-delay=".2s">
          <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: var(--header);">Let Us Take the Helm</h2>
          <p class="text-lg leading-relaxed mb-6" style="color: var(--text);">
            Our professional skippers know every hidden bay, secret beach and scenic route around Rhodes. They will navigate while you enjoy the views, swim in pristine waters and make the most of your day at sea.
          </p>
          <p class="text-lg leading-relaxed mb-6" style="color: var(--text);">
            Ideal for those who want a stress-free experience or need a licensed captain for larger vessels. Our skippers also double as local guides, sharing the history and culture of every stop along the way.
          </p>
          <a href="/contact" class="theme-btn">
            <span>Book Now <i class="bi bi-arrow-right"></i></span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
