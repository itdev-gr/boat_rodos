---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Licenses Free - Rodos Rent Boat">
  <section class="hero-2 bg-cover" style="background-image: url('/assets/img/charter-bases-visual.png')">
    <div class="container custom-container-3">
      <div class="row">
        <div class="col-lg-8">
          <div class="hero-content">
            <div class="sub-title">Rodos Rent Boat</div>
            <h1>Licenses Free</h1>
            <p>No boating license required. Easy to operate boats perfect for everyone.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-sky-50">
    <div class="container">
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
        <div class="w-full lg:w-1/2 wow fadeInUp">
          <div class="overflow-hidden rounded-2xl" style="box-shadow: rgb(56, 84, 107) -7px 7px 0px;">
            <img src="/assets/img/charter-bases-visual.png" alt="Licenses Free Boats" class="w-full h-[22rem] sm:h-[26rem] object-cover" />
          </div>
        </div>
        <div class="w-full lg:w-1/2 wow fadeInUp" data-wow-delay=".2s">
          <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: var(--header);">No License Needed</h2>
          <p class="text-lg leading-relaxed mb-6" style="color: var(--text);">
            Our license-free boats are designed for easy handling and are perfect for beginners and casual explorers. Simply hop on, follow a brief safety briefing and you are ready to discover the coastline of Rhodes on your own terms.
          </p>
          <p class="text-lg leading-relaxed mb-6" style="color: var(--text);">
            Available in various sizes for couples, families and small groups. All boats come equipped with sun canopy, cooler box, snorkeling gear and a detailed map of the best nearby beaches and swimming spots.
          </p>
          <a href="/contact" class="theme-btn">
            <span>Book Now <i class="bi bi-arrow-right"></i></span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
