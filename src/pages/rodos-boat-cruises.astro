---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Rodos Boat Cruises - Boat Rodos">
  <section class="hero-2 bg-cover" style="background-image: url('/assets/img/charter-bases-visual.png')">
    <div class="container custom-container-3">
      <div class="row">
        <div class="col-lg-8">
          <div class="hero-content">
            <div class="sub-title">Services</div>
            <h1>Rodos Boat Cruises</h1>
            <p>Full-day and half-day cruises along the beautiful coast of Rhodes.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-sky-50">
    <div class="container">
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
        <div class="w-full lg:w-1/2 wow fadeInUp">
          <div class="overflow-hidden rounded-2xl" style="box-shadow: rgb(56, 84, 107) -7px 7px 0px;">
            <img src="/assets/img/charter-bases-visual.png" alt="Rodos Boat Cruises" class="w-full h-[22rem] sm:h-[26rem] object-cover" />
          </div>
        </div>
        <div class="w-full lg:w-1/2 wow fadeInUp" data-wow-delay=".2s">
          <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: var(--header);">Cruise the Aegean</h2>
          <p class="text-lg leading-relaxed mb-6" style="color: var(--text);">
            Embark on a full-day or half-day cruise along the coast of Rhodes. Swim in turquoise waters, enjoy freshly prepared meals on board and soak up the Mediterranean sun as you glide past ancient ruins and dramatic cliff faces.
          </p>
          <p class="text-lg leading-relaxed mb-6" style="color: var(--text);">
            Our cruises include visits to Lindos, Tsambika Beach, Anthony Quinn Bay and other iconic destinations. All meals, drinks and snorkeling gear are included in the price.
          </p>
          <a href="/contact" class="theme-btn">
            <span>Book a Cruise <i class="bi bi-arrow-right"></i></span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
