---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Rodos MISE - Boat Rodos">
  <section class="hero-2 bg-cover" style="background-image: url('/assets/img/charter-bases-visual.png')">
    <div class="container custom-container-3">
      <div class="row">
        <div class="col-lg-8">
          <div class="hero-content">
            <div class="sub-title">Services</div>
            <h1>Rodos MISE</h1>
            <p>Professional maritime services for yachts and vessels visiting Rhodes.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-sky-50">
    <div class="container">
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
        <div class="w-full lg:w-1/2 wow fadeInUp">
          <div class="overflow-hidden rounded-2xl" style="box-shadow: rgb(56, 84, 107) -7px 7px 0px;">
            <img src="/assets/img/charter-bases-visual.png" alt="Rodos MISE" class="w-full h-[22rem] sm:h-[26rem] object-cover" />
          </div>
        </div>
        <div class="w-full lg:w-1/2 wow fadeInUp" data-wow-delay=".2s">
          <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: var(--header);">Complete Maritime Support</h2>
          <p class="text-lg leading-relaxed mb-6" style="color: var(--text);">
            From provisioning and fueling to technical support and crew arrangements, we handle every detail so you can focus on enjoying your time at sea. Our team is available around the clock to assist with any maritime needs.
          </p>
          <p class="text-lg leading-relaxed mb-6" style="color: var(--text);">
            Services include yacht provisioning, fuel delivery, waste disposal, laundry, technical repairs, berth reservations, customs and port formalities, and concierge services for crew and guests.
          </p>
          <a href="/contact" class="theme-btn">
            <span>Get in Touch <i class="bi bi-arrow-right"></i></span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
