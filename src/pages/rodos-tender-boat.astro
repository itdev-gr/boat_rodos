---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Rodos Tender Boat - Boat Rodos">
  <section class="hero-2 bg-cover" style="background-image: url('/assets/img/charter-bases-visual.png')">
    <div class="container custom-container-3">
      <div class="row">
        <div class="col-lg-8">
          <div class="hero-content">
            <div class="sub-title">Services</div>
            <h1>Rodos Tender Boat</h1>
            <p>Fast and reliable tender boat transfers between your yacht and the shore.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-sky-50">
    <div class="container">
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
        <div class="w-full lg:w-1/2 wow fadeInUp">
          <div class="overflow-hidden rounded-2xl" style="box-shadow: rgb(56, 84, 107) -7px 7px 0px;">
            <img src="/assets/img/charter-bases-visual.png" alt="Rodos Tender Boat" class="w-full h-[22rem] sm:h-[26rem] object-cover" />
          </div>
        </div>
        <div class="w-full lg:w-1/2 wow fadeInUp" data-wow-delay=".2s">
          <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: var(--header);">Shore-to-Yacht Transfers</h2>
          <p class="text-lg leading-relaxed mb-6" style="color: var(--text);">
            Available around the clock, our tender service ensures smooth and comfortable transportation for you and your guests at any hour. Professional crew, modern vessels and punctual service guaranteed.
          </p>
          <p class="text-lg leading-relaxed mb-6" style="color: var(--text);">
            We cover all ports and anchorages around Rhodes including Mandraki Harbour, Kolona Port, Faliraki and Lindos Bay. Advance booking and on-demand service available.
          </p>
          <a href="/contact" class="theme-btn">
            <span>Book a Transfer <i class="bi bi-arrow-right"></i></span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
